FROM python:3.11-slim

# ── Pinned agent version ───────────────────────────────────────────────────────
# Keep in sync with _DEFAULT_QWENPAW_VERSION in pawbench/agents/impl/qwenpaw_agent.py.
ARG QWENPAW_VERSION=1.1.3

# ── Node.js version ────────────────────────────────────────────────────────────
# CoPaw-Pro uses node:slim as its base image.  Many QwenClawBench tasks execute
# Node.js scripts (e.g. skills/moltbook-auto-post/post.js) or run npm install
# to install dependencies (node-fetch, dayjs, express, …).  We add Node.js 20
# LTS here so the copaw agent can run those workloads without needing to
# install Node at task-runtime.
ARG NODE_MAJOR=20

# ── System packages ────────────────────────────────────────────────────────────
# Mirrors the key system-level tools present in the CoPaw-Pro image:
#   - build-essential / libssl-dev  : compile native npm modules (e.g. sharp)
#   - jq                            : JSON processing used in several task shell
#                                     scripts (e.g. web3 monitor, DeFi scripts)
#   - sqlite3                       : some tasks inspect / query SQLite databases
#   - git, curl, ca-certificates    : standard dev/networking tools
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        python3 python3-pip git curl wget ca-certificates gnupg \
        build-essential libssl-dev \
        jq sqlite3 \
        # ── GUI / desktop environment (required for gui_*_zh tasks) ────────
        xvfb \
        xfce4 \
        xfce4-terminal \
        xfce4-taskmanager \
        dbus \
        dbus-x11 \
        scrot \
        fonts-wqy-zenhei \
        fonts-wqy-microhei \
        # ── Chromium + X11 libraries (mirrors CoPaw-Pro Dockerfile) ──────
        chromium \
        chromium-sandbox \
        libx11-xcb1 \
        libxcomposite1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxi6 \
        libxtst6 \
        libnss3 \
        libglib2.0-0 \
        libdrm2 \
        libgbm1 \
        libasound2 \
        fonts-liberation \
    && \
    # Patch chromium wrapper to add --no-sandbox (same as CoPaw-Pro)
    sed -i 's/^CHROMIUM_FLAGS=""/CHROMIUM_FLAGS="--no-sandbox"/' /usr/bin/chromium 2>/dev/null || true && \
    # ── Node.js 20 LTS via NodeSource ─────────────────────────────────────────
    mkdir -p /etc/apt/keyrings && \
    curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key \
        | gpg --dearmor -o /etc/apt/keyrings/nodesource.gpg && \
    echo "deb [signed-by=/etc/apt/keyrings/nodesource.gpg] \
        https://deb.nodesource.com/node_${NODE_MAJOR}.x nodistro main" \
        > /etc/apt/sources.list.d/nodesource.list && \
    apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends nodejs && \
    rm -rf /var/lib/apt/lists/*

# ── Playwright: use system Chromium (mirrors CoPaw-Pro) ───────────────────────
# Prevents Playwright from trying to download its own browser at runtime.
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV COPAW_RUNNING_IN_CONTAINER=1

# ── qwenpaw agent ─────────────────────────────────────────────────────────────
RUN pip install --no-cache-dir "qwenpaw==${QWENPAW_VERSION}"

# ── Common Python packages used across QwenClawBench tasks ────────────────────
# Pre-installing these avoids per-task pip install waits and network failures.
# Sources: requirements.txt files found in task assets across all 100 tasks.
RUN pip install --no-cache-dir \
    requests \
    pyyaml \
    urllib3 \
    pandas \
    numpy \
    matplotlib \
    Pillow \
    scikit-learn \
    python-docx \
    yfinance \
    certifi

# ── Pre-create the workspace directory layout ──────────────────────────────────
RUN mkdir -p /app/working/workspaces/default/output \
             /root/.qwenpaw/workspaces/default/output \
             /root/.copaw/workspaces/default/output

# ── Pre-initialize copaw workspace (mirrors CoPaw-Pro `copaw init`) ───────────
# Runs at build time so each task container starts with skills & config ready,
# avoiding per-task init delays and skill-download failures.
RUN qwenpaw init --defaults --accept-security 2>/dev/null || \
    copaw  init --defaults --accept-security 2>/dev/null || \
    echo "[copaw-init] skipped (init not available in this version)"

# ── ossutil（运行时从 OSS 拉单任务）────────────────────────────────────────────
RUN curl -fsSL https://gosspublic.alicdn.com/ossutil/1.7.18/ossutil64 \
    -o /usr/local/bin/ossutil && chmod +x /usr/local/bin/ossutil

# ── copawbench runner 代码（供 main.sh 调用）────────────────────────────────────
COPY pawbench/         /opt/copawbench/pawbench/
COPY run_bench.py      /opt/copawbench/run_bench.py
COPY requirements.txt  /opt/copawbench/requirements.txt
RUN pip install --no-cache-dir -r /opt/copawbench/requirements.txt
ENV PYTHONPATH=/opt/copawbench

# ── Smoke-tests ───────────────────────────────────────────────────────────────
RUN ossutil --version
RUN cd /opt/copawbench && python3 -c "import pawbench; print('pawbench runner OK')"
RUN qwenpaw --version 2>/dev/null || echo "qwenpaw ${QWENPAW_VERSION} installed"
RUN node --version && npm --version
RUN python3 -c "import requests, yaml, pandas, numpy; print('Python deps OK')"
RUN chromium --version 2>/dev/null || chromium-browser --version 2>/dev/null || echo "[warn] chromium not found"
RUN python3 -c "import playwright; print('playwright OK')"
