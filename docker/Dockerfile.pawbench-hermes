# docker/Dockerfile.hermes
#
# Base image for Hermes Agent benchmark evaluation.
# Mirrors the system-level setup of Dockerfile.openclaw so both agents see
# the same environment (Chromium, X11/XFCE4, Chinese fonts, Python deps).
#
# Build:
#   docker build -f docker/Dockerfile.hermes -t hermes-bench:latest .
#
# This image is used as the FROM base for:
#   docker/Dockerfile.pawbench-hermes
#   docker/Dockerfile.qwenclawbench-hermes

# Node.js 22 slim gives us Node + npm needed by hermes browser tools.
FROM node:22-slim

# ── Pinned versions ────────────────────────────────────────────────────────────
ARG HERMES_VERSION=2026.4.23

# ── System packages ────────────────────────────────────────────────────────────
# Mirrors Dockerfile.openclaw: Chromium + X11 + XFCE4 (gui_*_zh tasks) +
# Python 3.11 + common dev tools.
RUN apt-get update && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        # ── Python runtime ────────────────────────────────────────────────────
        python3 \
        python3-pip \
        python3-venv \
        # ── Common dev / networking ───────────────────────────────────────────
        git \
        curl \
        wget \
        ca-certificates \
        gnupg \
        build-essential \
        libssl-dev \
        jq \
        sqlite3 \
        ripgrep \
        # ── Chromium + X11 libraries ──────────────────────────────────────────
        chromium \
        chromium-sandbox \
        libx11-xcb1 \
        libxcomposite1 \
        libxdamage1 \
        libxext6 \
        libxfixes3 \
        libxi6 \
        libxtst6 \
        libnss3 \
        libglib2.0-0 \
        libdrm2 \
        libgbm1 \
        libasound2 \
        fonts-liberation \
        # ── Virtual desktop + XFCE4 (gui_*_zh screenshot tasks) ─────────────
        xvfb \
        xfce4 \
        xfce4-terminal \
        xfce4-taskmanager \
        dbus \
        dbus-x11 \
        scrot \
        # ── Chinese fonts ─────────────────────────────────────────────────────
        fonts-wqy-zenhei \
        fonts-wqy-microhei \
    && rm -rf /var/lib/apt/lists/*

# Allow Chromium to run as root inside the container (matches openclaw image).
RUN sed -i 's/^CHROMIUM_FLAGS=""/CHROMIUM_FLAGS="--no-sandbox"/' \
        /usr/bin/chromium 2>/dev/null || true

# Point hermes (and any Playwright usage) at the system Chromium so it never
# tries to download a browser at task-runtime.
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium
ENV PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
ENV COPAW_RUNNING_IN_CONTAINER=1

# ── Install uv (fast Python package manager used by hermes) ───────────────────
RUN curl -LsSf https://astral.sh/uv/install.sh | env HOME=/root sh && \
    ln -sf /root/.local/bin/uv /usr/local/bin/uv

# ── Install Hermes Agent ───────────────────────────────────────────────────────
# Try PyPI first; fall back to git-clone + uv install from source.
# Both paths produce the same `/usr/local/bin/hermes` binary.
RUN pip install --no-cache-dir "hermes-agent==${HERMES_VERSION}" 2>/dev/null && \
        echo "hermes installed from PyPI" || \
    ( \
        git clone --depth 1 --branch "v${HERMES_VERSION}" \
            https://github.com/NousResearch/hermes-agent.git /opt/hermes && \
        cd /opt/hermes && \
        uv venv /opt/hermes-venv --python 3.11 && \
        uv pip install -e ".[all]" --python /opt/hermes-venv/bin/python3 && \
        ln -sf /opt/hermes-venv/bin/hermes /usr/local/bin/hermes && \
        echo "hermes installed from git" \
    )

# ── Seed a minimal hermes config (no wizard, no API key needed) ───────────────
# Sets approvals.mode=off (benchmark mode: no interactive confirmations) and
# pre-points the workspace at /app/working/workspaces/default so it matches
# the copaw/openclaw workspace layout that PawBench graders expect.
RUN mkdir -p /root/.hermes && \
    printf '%s\n' \
        'version: 1' \
        'approvals:' \
        '  mode: off' \
        'agents:' \
        '  defaults:' \
        '    workspace: /app/working/workspaces/default' \
    > /root/.hermes/config.yaml

# ── Common Python packages pre-installed for PawBench / QwenClawBench tasks ──
# node:22-slim uses Debian bookworm which marks the system Python as
# "externally managed" (PEP 668); --break-system-packages is required to
# install packages into it.  The alternative would be a venv, but all existing
# PawBench/QwenClawBench task scripts call `python3` directly, so system-level
# install is the right choice here (matches Dockerfile.openclaw).
RUN pip install --no-cache-dir --break-system-packages \
    requests \
    pyyaml \
    urllib3 \
    pandas \
    numpy \
    matplotlib \
    Pillow \
    scikit-learn \
    python-docx \
    yfinance \
    certifi \
    fastapi \
    uvicorn \
    httpx \
    openai \
    oss2 \
    pytest

# ── Pre-create workspace directories ──────────────────────────────────────────
RUN mkdir -p /app/working/workspaces/default/output \
             /app/working/workspaces/default/sessions \
             /root/.hermes/sessions

# ── ossutil（运行时从 OSS 拉单任务）────────────────────────────────────────────
RUN curl -fsSL https://gosspublic.alicdn.com/ossutil/1.7.18/ossutil64 \
    -o /usr/local/bin/ossutil && chmod +x /usr/local/bin/ossutil

# ── copawbench runner 代码（供 main.sh 调用）────────────────────────────────────
COPY pawbench/         /opt/copawbench/pawbench/
COPY run_bench.py      /opt/copawbench/run_bench.py
COPY requirements.txt  /opt/copawbench/requirements.txt
RUN pip3 install --no-cache-dir --break-system-packages \
    -r /opt/copawbench/requirements.txt || \
    pip3 install --no-cache-dir -r /opt/copawbench/requirements.txt
ENV PYTHONPATH=/opt/copawbench

# ── Smoke tests ───────────────────────────────────────────────────────────────
RUN ossutil --version
RUN cd /opt/copawbench && python3 -c "import pawbench; print('pawbench runner OK')"
RUN hermes --version 2>/dev/null || echo "hermes ${HERMES_VERSION} installed"
RUN node --version && npm --version
RUN python3 --version
RUN chromium --version 2>/dev/null || \
    chromium-browser --version 2>/dev/null || \
    echo "[warn] chromium not found"
RUN python3 -c "import requests, yaml, pandas, numpy; print('Python deps OK')"
