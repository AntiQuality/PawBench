# PawBench environment variables
# Copy to .env and fill in real values. .env is gitignored.
#
#   cp .env.example .env
#
# At minimum you need ONE model provider (below) plus a judge endpoint
# (used by llm_judge / hybrid grading modes).


# ── Model provider: DashScope (recommended default) ───────────────────────────
# Used by --model dashscope/qwen3.6-plus etc.
DASHSCOPE_API_KEY=
# Optional override; default is https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=


# ── Model provider: OpenAI / OpenAI-compatible ────────────────────────────────
# Used by --model openai/gpt-4o etc. Also serves as a generic fallback when a
# provider-specific key is not set.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1


# ── Model provider: Custom (OpenAI-compatible proxy) ──────────────────────────
# Used by --model custom/<model-name>. Useful for self-hosted gateways or
# private proxies. Takes precedence over OPENAI_* for custom-prefixed models.
# CUSTOM_API_KEY=
# CUSTOM_BASE_URL=


# ── Other model providers (set only the ones you use) ────────────────────────
# ALIYUN_API_KEY=
# GOOGLE_GEMINI_API_KEY=
# GOOGLE_AI_STUDIO_API_KEY=
# AZURE_OPENAI_API_VERSION=2023-05-15


# ── LLM judge (required for llm_judge / hybrid graded tasks) ──────────────────
# Falls back to OPENAI_API_KEY / OPENAI_BASE_URL if unset.
JUDGE_API_KEY=
JUDGE_BASE_URL=
# Defaults to claude-opus-4-5-20251101 when unset; override per run with --judge.
# JUDGE_MODEL=


# ── Default model fallback (when --model is not passed) ──────────────────────
# OPENAI_MODEL=openai/gpt-4o


# ── Web search (only needed for tasks with external_dependency: internet) ────
# Free tier at https://brave.com/search/api/
# BRAVE_API_KEY=


# ── Optional: keep agent workspaces after each task for inspection ───────────
# QWENCLAWBENCH_KEEP_WORKSPACE=1
# PAWBENCH_KEEP_WORKSPACE=1
